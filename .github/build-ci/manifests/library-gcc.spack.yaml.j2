spack:
  specs:
  # package is defined in the workflows inputs.spack-manifest-data-pairs
  # gcc_compiler_ver is defined in the standard_definitions.json data file
  - cable@git.{{ ref }} +mpi library=access3
  - cable@git.{{ ref }} ~mpi library=access3
  packages:
    gcc:
      require:
        - '@13.2.0'
    all:
      require:
        - '%access_gcc'
        - target=x86_64
  concretizer:
    unify: false
  view: false
