spack:
  specs:
  - cable@git.{{ ref }}
  packages:
    python:
      require:
        - '@3.11.14'
    intel-oneapi-compilers-classic:
      require:
      - '@2021.10.0'
    all:
      require:
      - '%access_intel'  # https://github.com/ACCESS-NRI/spack-config/blob/main/v1.1/toolchains.yaml
      - target=x86_64
  concretizer:
    unify: false
  view: false
